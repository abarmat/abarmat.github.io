---
layout: base-with-nav.njk
title: Posts | abarmat.com
nav: posts
---

<div class="content">
  <section>
    <ul class="post-list">
      {%- for post in collections.post | reverse -%}
      <li class="post">
        <small class="post-date">
          {{ post.date | dateFilter }}
        </small>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      {%- endfor -%}
    </ul>
  </section>
</div>
