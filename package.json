{
  "name": "abarmat-site",
  "version": "1.0.0",
  "author": "Ariel Barmat",
  "description": "Ariel Barmat : Personal Site",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/build.mjs --serve",
    "dev": "node scripts/build.mjs --serve",
    "build": "node scripts/build.mjs",
    "format": "prettier --write src/**/*.{js,jsx}",
    "test": "node --test tests/site-build.test.mjs",
    "deploy": "node scripts/build.mjs && gh-pages -d dist -b main",
    "spellcheck": "cspell lint --no-progress"
  },
  "keywords": [],
