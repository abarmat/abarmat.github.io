  "repository": {
    "type": "git",
    "url": "https://github.com/abarmat/abarmat.github.io"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@mightyplow/eleventy-plugin-cache-buster": "^1.1.3",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "cspell": "^9.7.0",
    "gh-pages": "^6.1.1",
    "clean-css": "^5.3.3",
    "html-minifier": "^4.0.0",
    "lefthook": "^2.1.4"
  },
  "dependencies": {
    "@11ty/eleventy-plugin-rss": "^2.0.4"
  },
  "packageManager": "bun@1.3.5"
